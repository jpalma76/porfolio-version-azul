---

interface Props {
    name: string
    url: string
}

const { name, url } = Astro.props;

---
<li
    class="badge w-[170px] flex items-center justify-center px-auto py-2 border-zinc-400 rounded-full text-sm"
>
    <img src={url} alt={name} class="size-5" />
    {name}
</li>

<style>
    .badge {
        display: flex;
        color: #fff;
        background-image: linear-gradient(45deg, silver 30%, #111 80%);
        border: 1px solid #efe060;
        font-size: 16px;
        font-weight: 600;
        gap: 8px;
    }
</style>
